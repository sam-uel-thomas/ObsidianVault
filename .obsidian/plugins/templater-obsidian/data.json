{
  "template_folder": "Templates",
  "trigger_on_new_file": true,
  "folder_templates": [
    {
      "folder": "01-Projects",
      "template": "Templates/Project Hub.md"
    },
    {
      "folder": "03-Daily",
      "template": "Templates/Daily Note.md"
    }
